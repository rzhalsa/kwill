    },
    {
      "name": "Goliath",
      "creature_type": "Humanoid",
      "size": "Medium (about 7-8 feet tall)",
      "speed": "35 feet",
      "traits": [
        {
          "name": "Giant Ancestry. You are descended from Giants",
          "description": "Choose one of the following benefits-a supernatural boon from your ancestry; you can use the chosen benefit a number of times equal to your Proficiency Bonus, and you regain all expended uses when you finish a Long Rest: Cloud's Jaunt (Cloud Giant). As a Bonus Action, you magically teleport up to 30 feet to an unoccupied space you can see. Fire's Burn (Fire Giant). When you hit a target with an attack roll and deal damage to it, you can also deal 1d10",
          "subraces": [
            {
              "name": "Fire damage to that target",
              "description": "Frost's Chill (Frost Giant). When you hit a target with an attack roll and deal damage to it, you can also deal 1d6 Cold damage to that target and reduce its Speed by 10 feet until the start of your next turn. Hill's Tumble (Hill Giant). When you hit a Large or smaller creature with an attack roll and deal damage to it, you can give that target the"
            },
            {
              "name": "Prone condition",
              "description": "Stone's Endurance (Stone Giant). When you take damage, you can take a Reaction to roll 1d12."
            },
            {
              "name": "Add your Constitution modifier to the number rolled and reduce the damage by that total",
              "description": ""
            }
          ]
        }
